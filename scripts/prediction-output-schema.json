{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "predictions": {
      "type": "array",
      "minItems": 72,
      "maxItems": 72,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "matchId": { "type": "string" },
          "outcome": { "type": "string", "enum": ["WIN", "DRAW", "LOSS"] }
        },
        "required": ["matchId", "outcome"]
      }
    }
  },
  "required": ["predictions"]
}
